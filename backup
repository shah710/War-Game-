<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>War Game Beta v0.4</title>
  <style>
    * { box-sizing: border-box; }

    :root {
      --bg1: #091321;
      --bg2: #12263d;
      --bg3: #1d3d61;
      --panel: rgba(255,255,255,0.08);
      --panel-border: rgba(255,255,255,0.12);
      --soft: #dce8f6;
      --blue1: #2f7de1;
      --blue2: #7fc2ff;
      --red1: #c62828;
      --red2: #ff8d8d;
      --pink1: #ff4fd8;
      --pink2: #ffc0ef;
      --gold: #ffd166;
      --teal1: #00c2a8;
      --teal2: #6ef7d8;
      --violet1: #7b2cbf;
      --violet2: #c8a8ff;
      --green1: #22c55e;
      --green2: #86efac;
      --orange1: #f97316;
      --orange2: #fdba74;
      --shieldBlue: rgba(90, 190, 255, 0.35);
      --shieldRed: rgba(255, 110, 110, 0.35);
      --cloud: rgba(255,255,255,0.18);
      --cloud2: rgba(255,255,255,0.1);
    }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      color: white;
      text-align: center;
      overflow-x: hidden;
      background: radial-gradient(circle at top, #24486f 0%, var(--bg2) 32%, var(--bg1) 72%, #03070c 100%);
      perspective: 1200px;
    }

    body.shake-light { animation: shakeLight 0.22s linear; }
    body.shake-medium { animation: shakeMedium 0.34s linear; }
    body.shake-heavy { animation: shakeHeavy 0.58s linear; }

    @keyframes shakeLight {
      0% { transform: translate(0,0); }
      25% { transform: translate(-3px,2px); }
      50% { transform: translate(3px,-2px); }
      75% { transform: translate(-2px,-1px); }
      100% { transform: translate(0,0); }
    }
    @keyframes shakeMedium {
      0% { transform: translate(0,0); }
      20% { transform: translate(-6px,3px); }
      40% { transform: translate(6px,-3px); }
      60% { transform: translate(-4px,-4px); }
      80% { transform: translate(4px,3px); }
      100% { transform: translate(0,0); }
    }
    @keyframes shakeHeavy {
      0% { transform: translate(0,0); }
      15% { transform: translate(-10px,6px); }
      30% { transform: translate(10px,-6px); }
      45% { transform: translate(-8px,-7px); }
      60% { transform: translate(8px,6px); }
      75% { transform: translate(-6px,4px); }
      100% { transform: translate(0,0); }
    }

    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 20px;
    }

    h1 { margin: 0 0 8px; }

    .beta {
      display: inline-block;
      background: var(--gold);
      color: #111;
      padding: 8px 14px;
      border-radius: 999px;
      font-weight: bold;
      margin-bottom: 10px;
    }

    .subtitle {
      color: var(--soft);
      margin-bottom: 20px;
    }

    .panel {
      background: var(--panel);
      border: 1px solid var(--panel-border);
      border-radius: 20px;
      box-shadow: 0 14px 30px rgba(0,0,0,0.26), inset 0 1px 0 rgba(255,255,255,0.05);
      backdrop-filter: blur(10px);
      padding: 16px;
    }

    .setup-panel {
      max-width: 980px;
      margin: 0 auto 22px;
    }

    .setup-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 14px;
    }

    .setup-full { grid-column: 1 / -1; }

    label {
      display: block;
      text-align: left;
      margin-bottom: 6px;
      font-size: 14px;
      color: var(--soft);
    }

    input, select {
      width: 100%;
      padding: 13px 14px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.16);
      background: rgba(255,255,255,0.07);
      color: white;
      font-size: 16px;
      outline: none;
    }

    option { color: black; }

    .button-row {
      display: flex;
      gap: 10px;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    button {
      border: none;
      border-radius: 12px;
      padding: 13px 14px;
      font-size: 14px;
      font-weight: bold;
      cursor: pointer;
      color: white;
      transition: transform 0.15s ease, opacity 0.15s ease, filter 0.15s ease;
      box-shadow: 0 8px 18px rgba(0,0,0,0.25);
    }

    button:hover { transform: translateY(-2px); filter: brightness(1.05); }
    button:disabled { opacity: 0.45; cursor: not-allowed; transform: none; filter: none; }

    .btn-start, .btn-restart { background: #2a9d8f; }
    .btn-economy { background: #16a34a; }
    .btn-shield { background: linear-gradient(135deg, #2563eb, #60a5fa); }
    .btn-interceptor { background: linear-gradient(135deg, #7c3aed, #c4b5fd); }

    .top-row {
      display: flex;
      justify-content: center;
      gap: 14px;
      flex-wrap: wrap;
      margin-bottom: 14px;
      color: var(--soft);
      font-weight: bold;
    }

    .hud {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 18px;
    }

    .country-name {
      font-size: 22px;
      font-weight: bold;
      margin-bottom: 10px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .blue-text { color: #8ac8ff; }
    .red-text { color: #ff9c9c; }

    .section-label {
      font-size: 13px;
      color: #cbd8eb;
      text-align: left;
      margin: 6px 0 4px;
    }

    .bar-wrap {
      background: rgba(255,255,255,0.12);
      height: 24px;
      border-radius: 999px;
      overflow: hidden;
      margin-bottom: 8px;
      box-shadow: inset 0 2px 6px rgba(0,0,0,0.3);
    }

    .bar {
      height: 100%;
      width: 100%;
      transition: width 0.35s ease;
      position: relative;
      overflow: hidden;
    }

    .bar::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(255,255,255,0.2), transparent 60%);
      pointer-events: none;
    }

    .bar.health-blue { background: linear-gradient(90deg, var(--blue1), var(--blue2)); }
    .bar.health-red { background: linear-gradient(90deg, var(--red1), var(--red2)); }
    .bar.cp-blue { background: linear-gradient(90deg, #14b8a6, #8ff5e8); }
    .bar.cp-red { background: linear-gradient(90deg, #ff8a00, #ffd166); }
    .bar.money-blue { background: linear-gradient(90deg, var(--green1), var(--green2)); }
    .bar.money-red { background: linear-gradient(90deg, var(--orange1), var(--orange2)); }
    .bar.pop-blue { background: linear-gradient(90deg, #60a5fa, #bfdbfe); }
    .bar.pop-red { background: linear-gradient(90deg, #f87171, #fecaca); }
    .bar.shield-blue { background: linear-gradient(90deg, #0ea5e9, #bfdbfe); }
    .bar.shield-red { background: linear-gradient(90deg, #ef4444, #fecaca); }

    .stats {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      font-size: 13px;
      color: #d8e1ea;
      flex-wrap: wrap;
    }

    .economy-panel { margin-bottom: 18px; }

    .economy-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(160px, 1fr));
      gap: 12px;
      margin-top: 12px;
    }

    .eco-card {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      padding: 12px;
      text-align: left;
    }

    .eco-card b { display: block; margin-bottom: 6px; }

    .eco-meta {
      color: #d5e1f0;
      font-size: 13px;
      margin-bottom: 10px;
      line-height: 1.35;
    }

    .map-shell {
      position: relative;
      margin: 22px 0;
      transform-style: preserve-3d;
    }

    .globe-backdrop {
      position: absolute;
      inset: 30px 15% 40px 15%;
      border-radius: 50%;
      z-index: 0;
      opacity: 0.45;
      transform: rotateX(70deg) translateZ(-60px);
      background: radial-gradient(circle at 50% 45%, rgba(90,150,220,0.22), rgba(0,0,0,0) 55%), radial-gradient(circle at 50% 50%, rgba(255,255,255,0.08), rgba(0,0,0,0) 60%);
      filter: blur(2px);
    }

    .globe-backdrop::before,
    .globe-backdrop::after {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: 50%;
    }

    .globe-backdrop::before {
      background: repeating-linear-gradient(to right, rgba(255,255,255,0.08) 0 1px, transparent 1px 36px), repeating-linear-gradient(to bottom, rgba(255,255,255,0.06) 0 1px, transparent 1px 30px);
      animation: globeSpin 20s linear infinite;
      opacity: 0.65;
    }

    .globe-backdrop::after {
      background: radial-gradient(circle at 25% 38%, rgba(90,180,110,0.35) 0 12%, transparent 13%), radial-gradient(circle at 40% 58%, rgba(90,180,110,0.32) 0 10%, transparent 11%), radial-gradient(circle at 64% 40%, rgba(90,180,110,0.33) 0 13%, transparent 14%), radial-gradient(circle at 74% 64%, rgba(90,180,110,0.3) 0 9%, transparent 10%);
      animation: globeSpin 26s linear infinite reverse;
      filter: blur(1px);
      opacity: 0.7;
    }

    @keyframes globeSpin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    .map {
      position: relative;
      height: 540px;
      border-radius: 24px;
      overflow: hidden;
      background: url("https://eoimages.gsfc.nasa.gov/images/imagerecords/74000/74218/world.topo.bathy.200412.3x5400x2700.jpg") center / cover no-repeat;
      border: 1px solid rgba(255,255,255,0.15);
      box-shadow: 0 25px 60px rgba(0,0,0,0.7), inset 0 2px 0 rgba(255,255,255,0.1);
      transform: rotateX(10deg);
      cursor: crosshair;
    }

    .map.satellite-zoom { animation: satelliteZoom 2.4s ease-in-out; }

    @keyframes satelliteZoom {
      0% { transform: rotateX(8deg) scale(1); filter: saturate(1); }
      25% { transform: rotateX(8deg) scale(1.06); filter: saturate(1.1) brightness(1.05); }
      50% { transform: rotateX(8deg) scale(1.18); filter: saturate(1.25) brightness(1.12); }
      75% { transform: rotateX(8deg) scale(1.08); filter: saturate(1.1) brightness(1.04); }
      100% { transform: rotateX(8deg) scale(1); filter: saturate(1); }
    }

    .grid-lines::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: repeating-linear-gradient(to right, transparent 0, transparent 59px, rgba(255,255,255,0.04) 60px), repeating-linear-gradient(to bottom, transparent 0, transparent 59px, rgba(255,255,255,0.04) 60px);
      opacity: 0.35;
      z-index: 1;
    }

    .stars {
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 12% 16%, rgba(255,255,255,0.7) 0 1px, transparent 2px), radial-gradient(circle at 22% 8%, rgba(255,255,255,0.45) 0 1px, transparent 2px), radial-gradient(circle at 37% 12%, rgba(255,255,255,0.5) 0 1px, transparent 2px), radial-gradient(circle at 52% 18%, rgba(255,255,255,0.4) 0 1px, transparent 2px), radial-gradient(circle at 66% 10%, rgba(255,255,255,0.55) 0 1px, transparent 2px), radial-gradient(circle at 79% 15%, rgba(255,255,255,0.5) 0 1px, transparent 2px), radial-gradient(circle at 88% 9%, rgba(255,255,255,0.6) 0 1px, transparent 2px);
      opacity: 0.55;
      pointer-events: none;
      z-index: 0;
    }

    .world-map-bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
      opacity: 0.22;
      pointer-events: none;
    }

    .continent {
      fill: #4d7a4f;
      stroke: rgba(255,255,255,0.08);
      stroke-width: 2;
      filter: drop-shadow(0 6px 10px rgba(0,0,0,0.22));
    }

    .weather-layer, .city-layer, .target-layer, .defense-layer, .projectile-layer {
      position: absolute;
      inset: 0;
    }

    .weather-layer { z-index: 5; pointer-events: none; }
    .city-layer { z-index: 6; }
    .target-layer { z-index: 10; pointer-events: none; }
    .defense-layer { z-index: 8; pointer-events: none; }
    .projectile-layer { z-index: 9; pointer-events: none; }

    .city-node {
      position: absolute;
      width: 22px;
      height: 22px;
      margin-left: -11px;
      margin-top: -11px;
      border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.9);
      box-shadow: 0 0 18px rgba(255,255,255,0.65);
      cursor: pointer;
      transition: transform 0.14s ease, filter 0.14s ease;
    }

    .city-node:hover { transform: scale(1.08); filter: brightness(1.08); }
    .city-node.player { background: #8ecaff; }
    .city-node.enemy { background: #ff9c9c; }
    .city-node.safe { box-shadow: 0 0 14px rgba(86, 255, 155, 0.65); }
    .city-node.threatened { box-shadow: 0 0 16px rgba(255, 209, 102, 0.9); }
    .city-node.attack { box-shadow: 0 0 22px rgba(255, 99, 99, 1); animation: pulseAttack 0.9s infinite; }

    .city-label {
      position: absolute;
      transform: translate(-50%, 10px);
      color: #eef6ff;
      font-size: 13px;
      font-weight: bold;
      text-shadow: 0 2px 6px rgba(0,0,0,0.75);
      white-space: nowrap;
      pointer-events: none;
    }

    .city-meta {
      position: absolute;
      transform: translate(-50%, 28px);
      color: #dbeafe;
      font-size: 11px;
      white-space: nowrap;
      pointer-events: none;
    }

    @keyframes pulseAttack {
      0% { transform: scale(1); }
      50% { transform: scale(1.18); }
      100% { transform: scale(1); }
    }

    .reticle {
      position: absolute;
      width: 54px;
      height: 54px;
      border: 2px solid rgba(255,255,255,0.92);
      border-radius: 50%;
      transform: translate(-50%, -50%);
      box-shadow: 0 0 16px rgba(255,255,255,0.65);
      animation: reticlePulse 1.1s infinite;
    }

    .reticle::before,
    .reticle::after {
      content: "";
      position: absolute;
      left: 50%;
      top: 50%;
      background: rgba(255,255,255,0.92);
      transform: translate(-50%, -50%);
    }

    .reticle::before { width: 2px; height: 74px; }
    .reticle::after { width: 74px; height: 2px; }

    @keyframes reticlePulse {
      0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
      50% { transform: translate(-50%, -50%) scale(1.08); opacity: 0.82; }
    }

    .target-hint {
      position: absolute;
      transform: translate(-50%, -72px);
      background: rgba(0,0,0,0.55);
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: 10px;
      padding: 8px 10px;
      color: white;
      font-size: 12px;
      min-width: 160px;
    }

    .shield-dome {
      position: absolute;
      width: 92px;
      height: 92px;
      border-radius: 50%;
      transform: translate(-50%, -50%);
      border: 2px solid rgba(255,255,255,0.45);
      box-shadow: 0 0 28px rgba(120,200,255,0.35), inset 0 0 18px rgba(255,255,255,0.12);
      backdrop-filter: blur(1px);
      animation: shieldPulse 2s infinite ease-in-out;
    }

    .shield-dome.player {
      background: radial-gradient(circle, rgba(110, 195, 255, 0.18), transparent 65%);
      border-color: rgba(110, 195, 255, 0.7);
    }
    .shield-dome.enemy {
      background: radial-gradient(circle, rgba(255, 115, 115, 0.18), transparent 65%);
      border-color: rgba(255, 115, 115, 0.7);
    }

    @keyframes shieldPulse {
      0%, 100% { opacity: 0.7; transform: translate(-50%, -50%) scale(1); }
      50% { opacity: 0.95; transform: translate(-50%, -50%) scale(1.06); }
    }

    .interceptor-arc {
      position: absolute;
      height: 3px;
      transform-origin: left center;
      background: linear-gradient(90deg, rgba(160,255,255,0.15), rgba(160,255,255,0.95));
      box-shadow: 0 0 12px rgba(160,255,255,0.95);
      border-radius: 999px;
      animation: interceptorFade 0.9s linear forwards;
    }

    @keyframes interceptorFade {
      0% { opacity: 1; }
      100% { opacity: 0; }
    }

    .cloud-band {
      position: absolute;
      width: 220px;
      height: 90px;
      border-radius: 999px;
      background: radial-gradient(circle at 30% 50%, var(--cloud) 0 35%, transparent 36%), radial-gradient(circle at 50% 40%, var(--cloud) 0 38%, transparent 39%), radial-gradient(circle at 70% 54%, var(--cloud2) 0 30%, transparent 31%), linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.02));
      filter: blur(4px);
      opacity: 0.55;
      animation: driftCloud linear infinite;
    }

    @keyframes driftCloud {
      from { transform: translateX(-260px); }
      to { transform: translateX(1320px); }
    }

    .projectile {
      position: absolute;
      z-index: 7;
      border-radius: 999px;
      pointer-events: none;
      box-shadow: 0 0 12px rgba(255,255,255,0.8);
      transform: translate(-50%, -50%);
    }

    .projectile.drone { width: 12px; height: 12px; background: radial-gradient(circle, #ffffff 10%, #b7f3ff 80%); box-shadow: 0 0 10px rgba(183,243,255,0.9); }
    .projectile.missile { width: 18px; height: 8px; background: linear-gradient(90deg, #ffffff, #ffdd57); }
    .projectile.pink { width: 22px; height: 9px; background: linear-gradient(90deg, #fff, var(--pink2), var(--pink1)); box-shadow: 0 0 18px rgba(255,79,216,0.95); }
    .projectile.cruise { width: 24px; height: 9px; background: linear-gradient(90deg, #ffffff, #6ef7d8); box-shadow: 0 0 14px rgba(110,247,216,0.9); }
    .projectile.ballistic { width: 28px; height: 10px; background: linear-gradient(90deg, #ffffff, var(--violet2)); box-shadow: 0 0 16px rgba(179,136,255,0.9); }
    .projectile.emp { width: 22px; height: 22px; background: radial-gradient(circle, rgba(180,255,255,0.95), rgba(0,255,240,0.2)); box-shadow: 0 0 18px rgba(120,255,255,0.95); border-radius: 50%; }
    .projectile.nuclear { width: 38px; height: 13px; background: linear-gradient(90deg, #ffffff, #ff6b6b); box-shadow: 0 0 20px rgba(255,120,120,0.95); }
    .projectile.hydrogen { width: 62px; height: 18px; background: linear-gradient(90deg, #ffffff, #fff0b3, #ff6a00, #ff2f2f); box-shadow: 0 0 34px rgba(255,150,40,1); }
    .projectile.ship { width: 40px; height: 16px; border-radius: 8px 8px 5px 5px; background: linear-gradient(180deg, #e2e8f0 0%, #94a3b8 40%, #475569 100%); box-shadow: 0 0 18px rgba(203,213,225,0.65); }
    .projectile.ship::before { content: ""; position: absolute; width: 14px; height: 6px; left: 12px; top: -4px; border-radius: 4px; background: #f8fafc; box-shadow: 0 0 8px rgba(255,255,255,0.5); }
    .projectile.ground { width: 26px; height: 12px; border-radius: 6px; background: linear-gradient(90deg, #f59e0b, #7c2d12); box-shadow: 0 0 16px rgba(245,158,11,0.7); }
    .projectile.interceptor { width: 14px; height: 14px; background: radial-gradient(circle, #fff, #9cf); box-shadow: 0 0 18px rgba(180,230,255,1); }

    .trail-dot {
      position: absolute;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      pointer-events: none;
      z-index: 6;
      transform: translate(-50%, -50%);
      animation: fadeTrail 0.45s linear forwards;
    }

    .wake-dot {
      position: absolute;
      width: 14px;
      height: 6px;
      border-radius: 999px;
      pointer-events: none;
      z-index: 6;
      transform: translate(-50%, -50%);
      background: rgba(220, 240, 255, 0.85);
      box-shadow: 0 0 8px rgba(220,240,255,0.65);
      animation: fadeWake 0.55s linear forwards;
    }

    .sea-splash {
      position: absolute;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      pointer-events: none;
      z-index: 8;
      transform: translate(-50%, -50%);
      background: radial-gradient(circle, rgba(255,255,255,0.95) 0%, rgba(170,220,255,0.8) 45%, rgba(170,220,255,0.05) 100%);
      animation: splashUp 0.8s ease-out forwards;
    }

    @keyframes fadeTrail {
      from { opacity: 0.95; transform: translate(-50%, -50%) scale(1); }
      to { opacity: 0; transform: translate(-50%, -50%) scale(0.3); }
    }

    @keyframes fadeWake {
      from { opacity: 0.9; transform: translate(-50%, -50%) scale(1); }
      to { opacity: 0; transform: translate(-50%, -50%) scale(0.55); }
    }

    @keyframes splashUp {
      0% { opacity: 1; transform: translate(-50%, -50%) scale(0.6); }
      40% { opacity: 0.95; transform: translate(-50%, calc(-50% - 10px)) scale(1.05); }
      100% { opacity: 0; transform: translate(-50%, calc(-50% - 18px)) scale(1.35); }
    }

    .explosion {
      position: absolute;
      width: 30px;
      height: 30px;
      border-radius: 50%;
      pointer-events: none;
      opacity: 0;
      z-index: 8;
      transform: translate(-50%, -50%) scale(0.2);
      --scale: 1.6;
    }

    .explosion.drone { background: radial-gradient(circle, #ffffff 0%, #9ef7ff 40%, rgba(0,180,255,0.18) 100%); }
    .explosion.missile { background: radial-gradient(circle, #fff7b1 0%, #ffb703 35%, #fb8500 65%, rgba(255,115,0,0.15) 100%); }
    .explosion.pink { background: radial-gradient(circle, #fff 0%, #ffd3f4 28%, #ff7add 58%, rgba(255,79,216,0.22) 100%); box-shadow: 0 0 24px rgba(255,79,216,0.85); }
    .explosion.cruise { background: radial-gradient(circle, #ffffff 0%, #7df4d9 30%, #14b8a6 62%, rgba(20,184,166,0.2) 100%); }
    .explosion.ballistic { background: radial-gradient(circle, #ffffff 0%, #ffd166 25%, #ff7b00 55%, #d62828 80%, rgba(214,40,40,0.22) 100%); }
    .explosion.emp { background: radial-gradient(circle, #e8ffff 0%, #6af7ff 35%, #00d4ff 65%, rgba(0,200,255,0.18) 100%); box-shadow: 0 0 28px rgba(0,200,255,0.65); }
