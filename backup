    };

    const $ = (id) => document.getElementById(id);

    function sanitizeName(name, fallback) {
      const cleaned = name.replace(/[<>]/g, "").trim();
      return cleaned.length ? cleaned : fallback;
    }

    function toggleModeFields() {
      mode = $("modeSelect").value;
      if (mode === "online") {
        alert("Online mode is disabled in this refined v0.4 build. Use Single Player.");
        $("modeSelect").value = "single";
        mode = "single";
      }
    }

    function updateLevelLocks() {
      const select = $("levelSelect");
      if (!select) return;
      for (let i = 0; i < select.options.length; i++) {
        const lvl = i + 1;
        const option = select.options[i];
        option.disabled = lvl > unlockedLevel;
        option.textContent = lvl > unlockedLevel ? `Level ${lvl} 🔒` : `Level ${lvl}`;
      }
      if (parseInt(select.value, 10) > unlockedLevel) select.value = String(unlockedLevel);
    }

    function unlockNextLevelIfNeeded() {
      if (level === unlockedLevel && unlockedLevel < 9) {
        unlockedLevel += 1;
        localStorage.setItem("warGameUnlockedLevel", String(unlockedLevel));
        updateLevelLocks();
        logMessage(`🔓 Level ${unlockedLevel} unlocked.`);
      }
    }

    function ensureAudio() {
      if (!audioCtx) {
        const AC = window.AudioContext || window.webkitAudioContext;
        if (AC) audioCtx = new AC();
      }
      if (audioCtx && audioCtx.state === "suspended") audioCtx.resume().catch(() => {});
    }

    function setupCustomAudio() {
      if (!customAudio.missile) customAudio.missile = new Audio("missile.mp3");
      if (!customAudio.ballistic) customAudio.ballistic = new Audio("ballistic.mp3");
      if (!customAudio.nuclear) customAudio.nuclear = new Audio("nuclear.mp3");
      if (!customAudio.siren) customAudio.siren = new Audio("siren.mp3");
      if (!customAudio.pink) customAudio.pink = new Audio("pink.mp3");
      Object.values(customAudio).forEach(a => { if (a) a.preload = "auto"; });
    }

    function playCustomAudio(key) {
      const a = customAudio[key];
      if (!a) return false;
      try { a.pause(); a.currentTime = 0; a.play().catch(() => {}); return true; } catch { return false; }
    }

    function playTone(freq, duration, type = "sine", volume = 0.08, startDelay = 0) {
      if (!audioCtx) return;
      const now = audioCtx.currentTime + startDelay;
      const osc = audioCtx.createOscillator();
